{
  "manifest_version": 3,
  "name": "AI 广播站",
  "description": "一键将消息广播到所有已打开的 AI 对话标签页",
  "version": "1.1",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://kimi.ai/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://minimaxi.com/*",
    "https://www.minimaxi.com/*",
    "https://chat.minimaxi.com/*",
    "https://agent.minimaxi.com/*",
    "https://hailuoai.com/*",
    "https://www.hailuoai.com/*",
    "https://aistudio.xiaomimimo.com/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.ai/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://minimaxi.com/*",
        "https://www.minimaxi.com/*",
        "https://chat.minimaxi.com/*",
        "https://agent.minimaxi.com/*",
        "https://hailuoai.com/*",
        "https://www.hailuoai.com/*",
        "https://aistudio.xiaomimimo.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
